# Environment variable overrides
# Copy this file to .env (git-ignored) and adjust values for your local run.
# The framework ships with safe defaults — you only need this file if you want
# to override them.

# Application base URL (default: https://www.saucedemo.com)
# BASE_URL=https://www.saucedemo.com

# SauceDemo test credentials (defaults match the documented stable test accounts)
# SAUCE_USERNAME=standard_user
# SAUCE_PASSWORD=secret_sauce

# Set to false to see the browser while running tests locally
# HEADLESS=true

# Automatically set to "true" in the GitHub Actions workflow
# CI=false

# Logger verbosity: debug | info | warn | error  (default: info)
# LOG_LEVEL=info
